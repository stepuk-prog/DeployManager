# ── БАЗА .env для WD (единый секрет-блок компонента) ──
# Оператор ведёт вручную. DeployManager рендерит финальный .env на ноду как:
#   <этот файл>  +  строки идентичности из vocabulary.nodes (см. ниже).
# Скопируй в env/WD.env и впиши реальные значения. Файл env/WD.env — gitignored.
# Идентичность (авто из БД, НЕ вписывать): WATCHDOG_NODE_ID=<nodes.id>, WATCHDOG_NODE_IP=<nodes.ip_address>, WATCHDOG_NODE_NAME=<nodes.server_name>
# ============================================================================
# Watchdog2 — пример .env. Скопируй в .env и заполни актуальными значениями.
# ============================================================================

# ---- PostgreSQL (через локальный HAProxy_client → текущий Patroni leader) ----
PG_HOST=127.0.0.1
PG_PORT=6442
PG_USER=vova
PG_PASSWORD=changeme   # TODO: keyring/Vault — см. TODO.md
PG_DATABASE=servermanager2

# Pool tuning (опционально — defaults в common/config.py)
# PG_POOL_MIN_SIZE=5
# PG_POOL_MAX_SIZE=20
# PG_STATEMENT_TIMEOUT_MS=15000

# ---- Watchdog (идентификация узла) ----

# Интервалы / пороги (опционально)
# WATCHDOG_MAIN_LOOP_INTERVAL_SEC=1
# WATCHDOG_HIGH_CPU_THRESHOLD=80
# WATCHDOG_CRITICAL_CPU_THRESHOLD=90
# WATCHDOG_HIGH_RAM_THRESHOLD=80
# WATCHDOG_CRITICAL_RAM_THRESHOLD=90
# WATCHDOG_ERROR_THROTTLE_WINDOW_MIN=5

# ---- Logging ----
LOG_LEVEL=INFO
# LOG_FILE_PATH автоматически = /var/log/dispatcher/Watchdog/watchdog.log

# Telegram (если не нужен — оставь пустыми, handler автоматически no-op)
LOG_ENABLE_TELEGRAM=true
LOG_TELEGRAM_TOKEN=
LOG_TELEGRAM_REPORT_CHAT_ID=

# --- Форум-режим (одна супергруппа с topics) ---
# FORUM_CHAT_ID задан → отчёты роутятся по темам, а не в ERROR/REPORT выше.
# Две темы узла (отчёты/ошибки) создаются автоматически (nodes.tg_topic_*_id).
LOG_TELEGRAM_FORUM_CHAT_ID=
# 🚨 Alerts — общая тема, зеркало всех ERROR:
LOG_TELEGRAM_ALERTS_THREAD_ID=
# 📊 Отчёты — общая тема, Server Report всех узлов:
LOG_TELEGRAM_REPORTS_THREAD_ID=
