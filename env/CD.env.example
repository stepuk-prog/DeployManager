# ── БАЗА .env для CD (единый секрет-блок компонента) ──
# Оператор ведёт вручную. DeployManager рендерит финальный .env на ноду как:
#   <этот файл>  +  строки идентичности из vocabulary.nodes (см. ниже).
# Скопируй в env/CD.env и впиши реальные значения. Файл env/CD.env — gitignored.
# Идентичность ноды не нужна (роль CD определяется из БД по hostname).
# ============================================================================
# CronDispatcher2 — пример .env. Скопируй в .env и заполни актуальными значениями.
# ============================================================================

# ---- PostgreSQL (через локальный HAProxy_client → текущий Patroni leader) ----
PG_HOST=127.0.0.1
PG_PORT=6442
PG_USER=vova
PG_PASSWORD=changeme   # TODO: keyring/Vault
PG_DATABASE=Program

# Pool tuning (опционально — defaults в common/config.py)
# PG_POOL_MIN_SIZE=5
# PG_POOL_MAX_SIZE=20
# PG_STATEMENT_TIMEOUT_MS=15000

# ---- Logging ----
LOG_LEVEL=INFO
# LOG_FILE_PATH автоматически = /var/log/dispatcher/CronDispatcher/crondispatcher.log

# Telegram (если не нужен — оставь пустыми, handler автоматически no-op)
LOG_ENABLE_TELEGRAM=true
LOG_TELEGRAM_TOKEN=
LOG_TELEGRAM_ERROR_CHAT_ID=
LOG_TELEGRAM_REPORT_CHAT_ID=

# --- Форум-режим (одна супергруппа с topics) ---
# FORUM_CHAT_ID задан → репорты CD роутятся в тему Cron, а не в REPORT выше.
LOG_TELEGRAM_FORUM_CHAT_ID=
# 🚨 Alerts — общая тема, зеркало всех ERROR:
LOG_TELEGRAM_ALERTS_THREAD_ID=
# 🕒 Cron — тема для репортов CD:
LOG_TELEGRAM_CRON_THREAD_ID=
