# ── БАЗА .env для GD (единый секрет-блок компонента) ──
# Оператор ведёт вручную. DeployManager рендерит финальный .env на ноду как:
#   <этот файл>  +  строки идентичности из vocabulary.nodes (см. ниже).
# Скопируй в env/GD.env и впиши реальные значения. Файл env/GD.env — gitignored.
# Идентичность (авто из БД, НЕ вписывать): GD_NODE_ID=<nodes.id>, GD_NODE_HOSTNAME=<nodes.server_name>
# ============================================================================
# GlobalDispatcher2 — пример .env. Скопируй в .env и заполни актуальными значениями.
# ============================================================================

# ---- PostgreSQL (через локальный HAProxy_client → текущий Patroni leader) ----
PG_HOST=127.0.0.1
PG_PORT=6442
PG_USER=vova
PG_PASSWORD=changeme   # TODO: keyring/Vault
PG_DATABASE=Program

# Pool tuning (опционально — defaults в common/config.py)
# PG_POOL_MIN_SIZE=5
# PG_POOL_MAX_SIZE=20
# PG_STATEMENT_TIMEOUT_MS=15000
# PG_RO_TX_SPLIT_BRAIN_COOLDOWN_SEC=30

# ---- GD идентификация (какой cluster-узел запустил этот процесс) ----

# Интервалы (опционально, defaults в common/config.py:GlobalDispatcherSettings)
# GD_MAIN_LOOP_INTERVAL_SEC=2
# GD_LEADERSHIP_POLL_INTERVAL_SEC=10

# HTTP /health endpoint (Prometheus blackbox / systemd-cron / curl)
# GD_HEALTH_HTTP_HOST=127.0.0.1
# GD_HEALTH_HTTP_PORT=8089               # 8088 занят WD2
# GD_HEALTH_MAX_CYCLE_AGE_SEC=30.0

# Prometheus metrics
# GD_PROM_METRICS_ENABLED=true

# ---- Logging ----
LOG_LEVEL=INFO
# LOG_FILE_PATH автоматически = /var/log/dispatcher/GlobalDispatcher/globaldispatcher.log

# Telegram (если не нужен — оставь пустыми, handler автоматически no-op)
LOG_ENABLE_TELEGRAM=true
LOG_TELEGRAM_TOKEN=
LOG_TELEGRAM_ERROR_CHAT_ID=
LOG_TELEGRAM_REPORT_CHAT_ID=

# --- Форум-режим (одна супергруппа с topics) ---
# FORUM_CHAT_ID задан → репорты GD роутятся в тему Диспетчера, а не в REPORT выше.
LOG_TELEGRAM_FORUM_CHAT_ID=
# 🚨 Alerts — общая тема, зеркало всех ERROR:
LOG_TELEGRAM_ALERTS_THREAD_ID=
# 🧭 Диспетчер — тема для репортов GD:
LOG_TELEGRAM_DISPATCHER_THREAD_ID=
