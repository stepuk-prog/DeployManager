# Операторские SSH-ключи флота — ставятся в root+vova authorized_keys на КАЖДУЮ новую
# ноду (шаг operator_access). Сверх ключа Vlad'а (vlad-dm, приходит через --vova-pubkey).
# Канонический набор, чистые имена (23-07). Обновлять при ротации; см. реестр KEYS.md.
#
# servermanager2       — RSA, ключ бота ServerManager2 (PM). Без него PM не заходит под root.
# cluster_root@PRIMARY — ED25519, автоматизация кластера + терминальный доступ коллеги.
# root@primary-pq-f    — RSA, операторский ключ флота.
ssh-rsa  servermanager2
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIE7aO+LHrQVIuhbvu3oGIzVNDT/vDdpxVpJo7yVA0fto cluster_root@PRIMARY
ssh-rsa  root@primary-pq-f
