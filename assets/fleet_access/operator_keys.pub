# Операторские SSH-ключи флота — ставятся в root+vova authorized_keys на КАЖДУЮ новую
# ноду (шаг operator_access мастера «Настроить ноду»). Сверх твоего ключа (он приходит
# отдельно через --vova-pubkey/provision). Источник: эталонная нода флота, 2026-07-23.
# Формат: обычный authorized_keys (одна строка на ключ). Обновлять при ротации ключей.
#
# cluster_root@PRIMARY — ED25519, ключ операторов/автоматизации (терминальный доступ коллеги).
# root@primary-pq-f    — RSA-4096, операторский ключ флота.
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIE7aO+LHrQVIuhbvu3oGIzVNDT/vDdpxVpJo7yVA0fto cluster_root@PRIMARY
ssh-rsa  root@primary-pq-f
