# DeployManager — пример окружения. Скопировать: cp .env.example .env

# ----- PostgreSQL (БД Program, через PgBouncer) -----
PG_DATABASE=Program
PG_HOST=localhost
PG_PORT=6442
PG_USER=vova
PG_PASSWORD=changeme

# ----- SSH на ноды -----
# Подключение под vova (passwordless sudo для systemctl/cp в /etc).
SSH_USER=vova
SSH_KEY=~/.ssh/id_nodes        # приватный ключ для входа на ноды
SSH_PORT=22
SSH_CONNECT_TIMEOUT=10
# Привилегированные шаги (юниты в /etc, systemctl). Если у SSH_USER нет passwordless
# sudo — укажи root (тот же ключ): вход под root без sudo. Пусто → SSH_USER + sudo -n.
PRIV_USER=root
# Отдельный ключ для PRIV_USER, если ключ root лежит не там, где SSH_KEY. Пусто → SSH_KEY.
# PRIV_KEY=~/.ssh/id_root
# Пароли к зашифрованным ключам (если ключ под passphrase). Пусто → ключ без пароля.
# SSH_KEY_PASSPHRASE=...
# PRIV_KEY_PASSPHRASE=...

# ----- rsync -----
# 1 — удалять на сервере файлы, которых нет локально (--delete). По умолчанию 0 (безопасно).
RSYNC_DELETE=0

# Стартовая папка для «Обзор…» в GUI (где лежат проекты)
PROJECTS_DIR=~/PythonProjects

# Корень репозитория Dispatcher2.0 (control-plane: GD/WD/CD/DispatcherCtl + common).
# По умолчанию — PROJECTS_DIR/Dispatcher2.0; задать явно, если лежит в другом месте
# (тогда DM настраивается на любой машине независимо от PROJECTS_DIR).
# DISPATCHER_DIR=~/PythonProjects/Dispatcher2.0

# Пути к ИСХОДНИКАМ каждого control-plane компонента и common. По умолчанию — подпапки
# DISPATCHER_DIR (GlobalDispatcher2/Watchdog2/CronDispatcher2/DispatcherCtl/common). Задай
# явно, если компоненты разложены по-своему — DM настраивается на любую раскладку.
# GD_DIR=~/PythonProjects/Dispatcher2.0/GlobalDispatcher2
# WD_DIR=~/PythonProjects/Dispatcher2.0/Watchdog2
# CD_DIR=~/PythonProjects/Dispatcher2.0/CronDispatcher2
# DISPATCHERCTL_DIR=~/PythonProjects/Dispatcher2.0/DispatcherCtl
# COMMON_DIR=~/PythonProjects/Dispatcher2.0/common

# Reporter (кнопка «Reporter») и cluster-конфиги (фаза 2 «член кластера»). По умолчанию — в
# Clusters; задать явно при иной раскладке.
# REPORTER_DIR=~/PythonProjects/Clusters/programs/reporter
# CLUSTER_CONFIG_DIR=~/PythonProjects/Clusters/ConfigFiles/cluster-node

# Кнопка «pgBackRest» — копия бэкапа кластера на ЭТУ машину. PGBACKREST_LOCAL_DIR — куда класть
# (дефолт ~/pgbackrest_backup); PGBACKREST_REPO — путь репозитория НА cluster-нодах.
# PGBACKREST_LOCAL_DIR=~/pgbackrest_backup
# PGBACKREST_REPO=/home/vova/pgbackrest

# Суб-инструмент «Юзерботы (сессии)»: "<поле-FK в telegram.telegram>,<таблица-справочник>".
# По my_gram знаем, какой Telegram Desktop поднять при логине. Дефолт совпадает — можно не задавать.
TELEGRAM_APPS=my_gram,telegram_apps

# Суб-инструмент «Cookies» (OTC/Screen/TV/Binodex): второй пул БД (binodex), Telegram-уведомления,
# видимый браузер (headless=0). PG-креды берутся из общих PG_* выше. TG_TOKEN/TG_CHANNEL — свои.
PG_DB_PROGRAM=Program
PG_DB_BINODEX=binodex
TG_TOKEN=
TG_CHANNEL=
OTC_HEADLESS=0
BINODEX_HEADLESS=0
BINODEX_VW=1280
BINODEX_VH=800
